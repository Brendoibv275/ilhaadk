#
# SDR Ilha Ar - Ambiente local (single-instance Evolution)
# Copie para .env e preencha os valores reais.
#

# ===== Banco =====
# URI PostgreSQL (Supabase: Settings → Database → Connection string → URI com password).
# O pacote pip "supabase" (SUPABASE_URL + anon/publishable key) é API REST; este projeto usa SQL via psycopg — mantenha DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
DB_CONNECT_TIMEOUT_SECONDS=5
DB_CONNECT_RETRIES=2
DB_RETRY_BACKOFF_SECONDS=0.75

# ===== LLM / ADK =====
GOOGLE_API_KEY=
SDR_MODEL=gemini-3.1-flash-lite-preview
SDR_AUDIO_TRANSCRIBE_MODEL=gemini-3.1-flash-lite-preview
SDR_APP_NAME=sdr_ilha_ar
SDR_DEFAULT_CHANNEL=whatsapp
AUDIO_FETCH_TIMEOUT_SECONDS=15

# ===== Evolution (single-instance) =====
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=
PUBLIC_WEBHOOK_URL=

# ===== Notificacao interna =====
TECH_GROUP_JID=
ADMIN_WHATSAPP_NUMBER=
INTERNAL_NOTIFY_ADMIN_FALLBACK=1
EQUIPE_RESPONSAVEL=

# ===== Follow-up / regras =====
SIX_MONTH_FOLLOWUP_ENABLED=1
SIX_MONTH_FOLLOWUP_DAYS=180

# ===== Handoff humano =====
HUMAN_HANDOFF_FINALIZE_PATTERNS=obrigado,até a próxima,ate a proxima,finalizado,encerrado
HUMAN_HANDOFF_ALLOW_MANUAL_RESUME=1
HUMAN_HANDOFF_MANUAL_RESUME_COMMANDS=#retomarbot,#retomar,/retomar
HUMAN_HANDOFF_MIN_BOT_OUTBOUND=1
HUMAN_HANDOFF_MIN_STAGE=qualified

# ===== Opcional =====
GOOGLE_REVIEW_URL=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TTS_MARANHAO_STYLE=1
IGNORED_WHATSAPP_NUMBERS=
